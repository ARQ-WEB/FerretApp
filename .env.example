# ─────────────────────────────────────────────────────────────────────────────
# FerretApp – Variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env a git (ya está en .gitignore).
#
# Cómo funciona:
#   • Local (IntelliJ / mvn):  spring-dotenv carga este .env automáticamente.
#   • Docker:                  docker-compose lee el .env y lo inyecta como
#                              variables de entorno al contenedor; spring-dotenv
#                              NO necesita el archivo dentro del contenedor.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────
DB_NAME=ferretapp
DB_USER=ferretapp
DB_PASSWORD=cambia_esto_por_una_contrasena_segura

# ── JWT ───────────────────────────────────────
# Genera un secreto nuevo en EC2:
#   openssl rand -base64 64
JWT_SECRET=0C/ZZj9OCW7Q74lUM200BayaFq6u12EKyps4NLFQNufowubX5nE1DQT8XRdwv0zUBp7Tns1yhYlwzUCm3maQkg==

# ── Frontend (CORS) ───────────────────────────
# En producción coloca la URL real del frontend, ej:
#   FRONTEND_URL=http://54.123.45.67:4200
FRONTEND_URL=http://localhost:4200
